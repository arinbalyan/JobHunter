# ────────────────────────────────────────────────────
# JobHunter — Environment Variables
# ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository.
#
#     cp .env.example .env
#
# Then edit .env with your actual API keys and secrets.
# All values here are placeholders only.
# ────────────────────────────────────────────────────

# ─── Database (NeonDB / PostgreSQL) ─────────────────
# Required. Your NeonDB connection string.
# Get one at: https://console.neon.tech
# Format: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── LLM Provider API Keys ──────────────────────────
# At least one is required. Add more for redundancy.
# Keys are loaded at runtime; order determines priority.

# OpenRouter — primary provider (Gemma, Gemini, Claude, GPT, etc.)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq — fast inference provider (fallback for simple tasks)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — wafer-scale inference (fallback for simple tasks)
# Get key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# ─── Email (Gmail SMTP) ─────────────────────────────
# Required. Use a Gmail App Password, not your regular password.
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASS=
EMAIL_FROM_NAME=JobHunter Agent

# ─── Email Tracking Server ──────────────────────────
# URL of your deployed tracking server (or localhost for testing).
# Deploy separately via: go run ./cmd/tracker
TRACKING_SERVER_URL=http://localhost:8080
TRACKING_SERVER_PORT=8080

# ─── Bounce & Reply Detection (IMAP) ────────────────
# Same Gmail credentials. Used to scan inbox for bounces/replies.
IMAP_USER=${GMAIL_USER}
IMAP_PASS=${GMAIL_APP_PASS}
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ─── Scrappy Configuration ──────────────────────────
SCRAPY_PROXY=
SCRAPY_MEMORY_CAP_MB=100

# ─── Run Mode ───────────────────────────────────────
# once   → run once and exit (for cron/CI)
# daemon → run continuously
# cron   → run on a schedule
RUN_MODE=once
LOG_LEVEL=info

# ─── Email Sending Limits ───────────────────────────
MAX_EMAILS_PER_RUN=10
EMAIL_DELAY_SECONDS=30

# ─── LLM Router ─────────────────────────────────────
# Model for complex tasks (email generation, reasoning)
LLM_COMPLEX_MODEL=google/gemma-4-9b-it
# Model for simple tasks (classification, scoring)
LLM_SIMPLE_MODEL=google/gemma-4-9b-it

LLM_MAX_TOKENS_PER_RUN=50000
LLM_MAX_TOKENS_PER_REQUEST=2048

# ─── Job Search Criteria ────────────────────────────
JOB_SEARCH_TERMS=software engineer,golang developer,backend engineer
JOB_LOCATIONS=remote,new york,los angeles
JOB_SITES=linkedin,indeed,greenhouse,builtin

JOB_RESULTS_PER_SITE=25
JOB_HOURS_OLD=72
JOB_REMOTE_ONLY=true
JOB_TYPE=fulltime

# ─── User Profile (for experience matching) ─────────
USER_YEARS_EXPERIENCE=3
USER_CURRENT_ROLE=Software Engineer
USER_TARGET_ROLES=["Software Engineer","Backend Engineer","Golang Developer"]

# ────────────────────────────────────────────────────
# Plugin-Scoped Environment Variables
# ────────────────────────────────────────────────────
# Each plugin can define its own env vars prefixed with PLUGIN_{PLUGIN_ID}_.
# This avoids naming conflicts between plugins.
#
# Examples:
#   PLUGIN_JOBHUNTER_CUSTOM_FIELD=value
#   PLUGIN_COLD_EMAIL_API_KEY=xxx
#   PLUGIN_LINKEDIN_ACCESS_TOKEN=xxx
# ────────────────────────────────────────────────────
