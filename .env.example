# ─────────────────────────────────────────────────────
# JobHunter Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────

# ─── Database (NeonDB / PostgreSQL) ─────────────────
# Your NeonDB connection string. Get from NeonDB dashboard.
# Format: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# ─── LLM Provider API Keys ──────────────────────────
# At least one is required. The more you add, the better the round-robin.
# All keys go through OpenRouter unless specified otherwise.

# OpenRouter API Key (supports many models including Gemini, Claude, GPT)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Optional: Groq API Key (fast inference, good for simple tasks)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Optional: Cerebras API Key (wafer-scale, very fast)
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxx

# ─── Email (Gmail SMTP) ─────────────────────────────
# Use a Gmail App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Your email display name (shows as sender in recipient's inbox)
EMAIL_FROM_NAME="Your Name"

# ─── Email Tracking Server ──────────────────────────
# Self-hosted tracking server for open/click tracking.
# Deploy separately or use the built-in tracker binary.
# If using the same server, set to your public URL or localhost for testing.
TRACKING_SERVER_URL=http://localhost:8080
TRACKING_SERVER_PORT=8080

# ─── IMAP (Bounce & Reply Detection) ────────────────
# Same Gmail credentials. Used to scan inbox for bounces/replies.
IMAP_USER=${GMAIL_USER}
IMAP_PASS=${GMAIL_APP_PASS}
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ─── Scrappy Configuration ──────────────────────────
# Optional: Proxy for scraping (SOCKS5 or HTTP)
SCRAPY_PROXY=
# Max memory in MB for scrapping (0 = unlimited)
SCRAPY_MEMORY_CAP_MB=100

# ─── Application Settings ───────────────────────────
# Run mode: once | daemon | cron
RUN_MODE=once

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Max emails to send per run
MAX_EMAILS_PER_RUN=10

# Delay between emails (seconds) - anti-spam protection
EMAIL_DELAY_SECONDS=30

# ─── LLM Router Settings ────────────────────────────
# Model to use for complex tasks (email generation, reasoning)
LLM_COMPLEX_MODEL=google/gemma-4-9b-it

# Model to use for simple tasks (classification, scoring)
LLM_SIMPLE_MODEL=google/gemma-4-9b-it

# Max tokens to spend per run (0 = unlimited)
LLM_MAX_TOKENS_PER_RUN=50000

# Max tokens per single request
LLM_MAX_TOKENS_PER_REQUEST=2048

# ─── Job Search Criteria ────────────────────────────
# Comma-separated list of search terms
JOB_SEARCH_TERMS="software engineer,golang developer,backend engineer"

# Comma-separated list of locations
JOB_LOCATIONS="remote,new york,los angeles"

# Job boards to scrape (comma-separated, or "all")
JOB_SITES="linkedin,indeed,greenhouse,builtin"

# Max results per site
JOB_RESULTS_PER_SITE=25

# Hours old - only jobs posted within this window
JOB_HOURS_OLD=72

# Remote only?
JOB_REMOTE_ONLY=true

# Job type: fulltime | parttime | contract | internship
JOB_TYPE=fulltime

# ─── Experienced Level Filtering ────────────────────
# Your experience level for matching
USER_YEARS_EXPERIENCE=3
USER_CURRENT_ROLE="Software Engineer"
USER_TARGET_ROLES='["Software Engineer","Backend Engineer","Golang Developer"]'
