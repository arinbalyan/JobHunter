# ─────────────────────────────────────────────────────
# JobHunter Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────

# ─── Database (NeonDB / PostgreSQL) ─────────────────
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── LLM Provider API Keys ──────────────────────────
# OpenRouter (supports many models — Gemini, Claude, GPT, etc.)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Optional: Groq (fast inference)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Optional: Cerebras (wafer-scale, very fast)
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxx

# ─── Email (Gmail SMTP) ─────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME="Your Name"

# ─── Email Tracking Server ──────────────────────────
# Self-hosted open/click tracking server.
# Deploy via: go run ./cmd/tracker
TRACKING_SERVER_URL=http://localhost:8080
TRACKING_SERVER_PORT=8080

# ─── IMAP (Bounce & Reply Detection) ────────────────
# Same Gmail credentials. Used to scan inbox for bounces/replies.
IMAP_USER=${GMAIL_USER}
IMAP_PASS=${GMAIL_APP_PASS}
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ─── Scrappy Configuration ──────────────────────────
SCRAPY_PROXY=
SCRAPY_MEMORY_CAP_MB=100

# ─── Application Settings ───────────────────────────
# Run mode: once | daemon | cron
RUN_MODE=once

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Max emails to send per run
MAX_EMAILS_PER_RUN=10

# Delay between emails (seconds) — anti-spam protection
EMAIL_DELAY_SECONDS=30

# ─── LLM Router Settings ────────────────────────────
# Model for complex tasks (email generation, reasoning)
LLM_COMPLEX_MODEL=google/gemma-4-9b-it

# Model for simple tasks (classification, scoring)
LLM_SIMPLE_MODEL=google/gemma-4-9b-it

# Max tokens per run (0 = unlimited)
LLM_MAX_TOKENS_PER_RUN=50000

# Max tokens per single request
LLM_MAX_TOKENS_PER_REQUEST=2048

# ─── Job Search Criteria ────────────────────────────
# Comma-separated search terms, locations, sites
JOB_SEARCH_TERMS="software engineer,golang developer,backend engineer"
JOB_LOCATIONS="remote,new york,los angeles"
JOB_SITES="linkedin,indeed,greenhouse,builtin"

# Max results per site
JOB_RESULTS_PER_SITE=25

# Hours old — only jobs posted within this window
JOB_HOURS_OLD=72

# Remote only?
JOB_REMOTE_ONLY=true

# Job type: fulltime | parttime | contract | internship
JOB_TYPE=fulltime

# ─── User Profile (for experience matching) ─────────
USER_YEARS_EXPERIENCE=3
USER_CURRENT_ROLE="Software Engineer"
USER_TARGET_ROLES='["Software Engineer","Backend Engineer","Golang Developer"]'

# ─────────────────────────────────────────────────────
# Plugin-Scoped Environment Variables
# ─────────────────────────────────────────────────────
# Each plugin can have its own env vars prefixed with PLUGIN_{PLUGIN_ID}_.
# Example for a hypothetical "cold-email" plugin:
# PLUGIN_COLD_EMAIL_API_KEY=xxx
# PLUGIN_COLD_EMAIL_LIST_URL=https://example.com/emails.csv
# PLUGIN_COLD_EMAIL_MAX_PER_RUN=50
#
# This allows multiple plugins to coexist without env var name conflicts.
