# ────────────────────────────────────────────────────
# JobHunter — Secrets (Example)
# ────────────────────────────────────────────────────
# Copy to .env and fill in your actual values.
# .env is gitignored. For GitHub Actions, set these
# as repository secrets.
#
#   cp .env.example .env
# ────────────────────────────────────────────────────

# ─── Database (NeonDB / PostgreSQL) ─────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ─── Gmail SMTP ─────────────────────────────────────
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASS=your-16-char-app-password

# ─── Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── LLM Provider API Keys ──────────────────────────
# At least one required. Add all you have.
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk_...
TOGETHER_API_KEY=tgp_...
DEEPINFRA_API_KEY=
FIREWORKS_API_KEY=fw_...
HYPERBOLIC_API_KEY=sk_live_...
SAMBANOVA_API_KEY=
NVIDIA_API_KEY=nvapi-...
ZAI_API_KEY=

# ─── Scrappy (Go subprocess) ────────────────────────
SCRAPPY_INDEED_API_KEY= # Indeed API key
SCRAPPY_DICE_API_KEY=   # Dice client-side key

# Optional scrappy API keys (unlock more sites — see ~/projects/scrappy/.env.example)
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# CAREERJET_AFFID=
# FINDWORK_API_KEY=
# WEB3CAREER_API_TOKEN=
# JOBTECHDEV_API_KEY=
# AUTHENTICJOBS_API_KEY=

# ─── Vercel (tracking server deploy — optional) ─────
VERCEL_TOKEN=
