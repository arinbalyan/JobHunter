# ────────────────────────────────────────────────────
# JobHunter — Environment Variables
# ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository.
#
#     cp .env.example .env
#
# Then edit .env with your actual API keys and secrets.
# All values here are placeholders only.
#
# GITHUB REPOSITORY SECRETS:
#   If using GitHub Actions, add the secrets marked with [SECRET]
#   to your repo: Settings > Secrets and variables > Actions
#   https://github.com/arinbalyan/JobHunter/settings/secrets/actions
# ────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════
# REQUIRED SECRETS
# ════════════════════════════════════════════════════════

# ─── Database (NeonDB / PostgreSQL) ─────────────────
# [SECRET] Required. Your NeonDB connection string.
# Get one at: https://console.neon.tech
# Format: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── Scrappy Configuration ──────────────────────────
# [SECRET] Indeed API key (free, ~100 req/day). Without this, Indeed falls
# back to HTML scraping which rarely returns results.
# Get one at: https://developer.indeed.com/
SCRAPPY_INDEED_API_KEY=

# ─── Email (Gmail SMTP) ─────────────────────────────
# [SECRET] Required. Use a Gmail App Password, not your regular password.
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASS=
EMAIL_FROM_NAME=JobHunter Agent

# ─── LLM Provider (at least one required) ────────────
# [SECRET] OpenRouter — 28+ free models (Gemma 4, DeepSeek V4, Llama 405B, etc.)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ════════════════════════════════════════════════════════
# RECOMMENDED SECRETS
# ════════════════════════════════════════════════════════

# ─── Telegram Alerts ────────────────────────────────
# [SECRET] Get bot token from @BotFather on Telegram.
# Get chat ID by running: go run ./cmd/botid/
# Message your bot anything (even "hi"), and botid prints your chat ID.
# All workflows (scrape, send, followup, cleanup, bouncescan) send reports here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Bounce & Reply Detection (IMAP) ────────────────
# [SECRET] Usually same as GMAIL_USER / GMAIL_APP_PASS
# Used by: cmd/inbox (telemetry), cmd/bouncescan (bounce detection)
IMAP_USER=
IMAP_PASS=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ─── Email Tracking Server ───────────────────────────
# [SECRET] URL of your deployed tracking server (for open/click tracking).
# Deploy with: .github/workflows/deploy-tracker.yml
# Leave as localhost if not deployed yet (tracking is skipped).
TRACKING_SERVER_URL=http://localhost:8080
TRACKING_SERVER_PORT=8080

# ════════════════════════════════════════════════════════
# OPTIONAL LLM PROVIDERS (round-robin fallbacks)
# ════════════════════════════════════════════════════════
# All use OpenAI-compatible API. Add any/all for redundancy.
# The more you add, the better the router can load-balance.

# Groq — very fast (Llama 3.3 70B, Llama 3.1 8B)
# Get: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — wafer-scale fast inference
# Get: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Together AI — Llama 3.3 70B Turbo
# Get: https://api.together.xyz/
TOGETHER_API_KEY=

# DeepInfra — many open models
# Get: https://deepinfra.com/
DEEPINFRA_API_KEY=

# Fireworks AI — fast Llama 3.3 70B
# Get: https://fireworks.ai/
FIREWORKS_API_KEY=

# Hyperbolic — Meta Llama models
# Get: https://hyperbolic.xyz/
HYPERBOLIC_API_KEY=

# SambaNova — Meta-Llama 3.3 70B
# Get: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=

# NVIDIA NIM — Nemotron models
# Get: https://build.nvidia.com/
NVIDIA_API_KEY=

# Z.AI — GLM-4 (Chinese LLM)
# Get: https://open.bigmodel.cn/
ZAI_API_KEY=

# ════════════════════════════════════════════════════════
# SCRAPING CONFIGURATION
# ════════════════════════════════════════════════════════

# Proxy for scraping (optional)
SCRAPY_PROXY=
SCRAPY_MEMORY_CAP_MB=100

# ════════════════════════════════════════════════════════
# RUN BEHAVIOR
# ════════════════════════════════════════════════════════

RUN_MODE=once
LOG_LEVEL=info

# Email sending limits
MAX_EMAILS_PER_RUN=10
EMAIL_DELAY_SECONDS=30
DAILY_EMAIL_LIMIT=500           # Gmail's hard cap

# LLM Model & Token Budget
LLM_COMPLEX_MODEL=google/gemma-4-9b-it
LLM_SIMPLE_MODEL=google/gemma-4-9b-it
LLM_MAX_TOKENS_PER_RUN=50000
LLM_MAX_TOKENS_PER_REQUEST=2048

# Job search criteria
JOB_SEARCH_TERMS=software engineer,golang developer,backend engineer
JOB_LOCATIONS=remote,new york,los angeles
JOB_SITES=linkedin,indeed,greenhouse,builtin
JOB_RESULTS_PER_SITE=25
JOB_HOURS_OLD=72
JOB_SINCE_DATE=            # Absolute date filter (YYYY-MM-DD or RFC3339). Stricter of hours_old vs since_date wins.
JOB_REMOTE_ONLY=true
JOB_TYPE=fulltime

# User profile for experience matching
USER_YEARS_EXPERIENCE=3
USER_CURRENT_ROLE=Software Engineer
USER_TARGET_ROLES=["Software Engineer","Backend Engineer","Golang Developer"]

# Contact info (used in email footer)
CONTACT_NAME=
CONTACT_EMAIL=
CONTACT_PHONE=
CONTACT_PORTFOLIO=
CONTACT_GITHUB=
CONTACT_LINKEDIN=
CONTACT_CODOLIO=
RESUME_DRIVE_LINK=

# ────────────────────────────────────────────────────
# GITHUB ACTIONS SECRETS REFERENCE
# ────────────────────────────────────────────────────
# Add these to: https://github.com/arinbalyan/JobHunter/settings/secrets/actions
#
# Required:
#   DATABASE_URL        — NeonDB connection string
#   GMAIL_USER          — Gmail address
#   GMAIL_APP_PASS      — Gmail App Password
#   OPENROUTER_API_KEY  — OpenRouter API key
#
# Recommended:
#   TELEGRAM_BOT_TOKEN  — Telegram bot token for run reports
#   TELEGRAM_CHAT_ID    — Telegram chat ID for reports
#   TRACKING_SERVER_URL — Deployed tracking server URL
#   EMAIL_FROM_NAME     — Your name (shows as sender)
#
# Optional:
#   GROQ_API_KEY        — Groq API key
#   CEREBRAS_API_KEY    — Cerebras API key
#   TOGETHER_API_KEY    — Together AI API key
#   DEEPINFRA_API_KEY   — DeepInfra API key
#   FIREWORKS_API_KEY   — Fireworks AI API key
#   HYPERBOLIC_API_KEY  — Hyperbolic API key
#   SAMBANOVA_API_KEY   — SambaNova API key
#   NVIDIA_API_KEY      — NVIDIA NIM API key
#   ZAI_API_KEY         — Z.AI (GLM-4) API key
#   IMAP_USER           — Gmail address (for bounce scan)
#   IMAP_PASS           — Gmail App Password (for bounce scan)
#   RESUME_PATH         — Path to PDF resume (.agent-data/*.pdf auto-detected)
#   VERCEL_TOKEN        — Vercel deploy token (for deploy-tracker.yml)
# ────────────────────────────────────────────────────
